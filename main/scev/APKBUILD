# Contributor: Sol Astrius <claude@danielsol.dev>
# Maintainer: Sol Astrius <claude@danielsol.dev>
pkgname=scev
pkgver=0.1.0
pkgrel=0
pkgdesc="Scalar Evolution guest RPC CLI (Zig)"
url="https://github.com/SolAstrius/alpine-apks"
arch="x86_64 riscv64"
license="MPL-2.0"
# zig isn't listed in makedepends: we pull a specific upstream zig
# tarball from the CI workflow because Alpine's packaged zig is too
# old for the 0.16 APIs used in sources/scev. The build assumes zig
# is on $PATH.
# !check  — unit tests run in the zig-test CI job, not during apk build
# !tracedeps — the binary is statically linked musl; no shlib deps to scan
# !strip  — zig already strips ReleaseFast output; abuild would invoke
#           a cross-arch strip binary (riscv64-alpine-linux-musl-strip)
#           that isn't shipped for non-native arches
options="!check !tracedeps !strip"

# In-tree source: the Zig tree lives at ../../sources/scev in this
# monorepo. We skip abuild's fetch/source= machinery and copy the
# tree into the default $builddir ("$srcdir/$pkgname-$pkgver").
# Bump pkgver or pkgrel to force a rebuild.
unpack() {
	mkdir -p "$builddir"
	# cp -r (not -a): we can't preserve ownership inside the CI chroot,
	# and we don't need the mtime/owner fidelity -a gives.
	cp -r "$startdir/../../sources/$pkgname/." "$builddir/"
}

build() {
	case "$CARCH" in
		x86_64)  zigtarget="x86_64-linux-musl"  ;;
		riscv64) zigtarget="riscv64-linux-musl" ;;
		*) error "unsupported CARCH=$CARCH"; return 1 ;;
	esac
	zig build -Dtarget="$zigtarget" --release=fast --prefix "$builddir/zig-prefix"
}

package() {
	install -Dm755 "$builddir/zig-prefix/bin/scev" "$pkgdir/usr/bin/scev"
}
